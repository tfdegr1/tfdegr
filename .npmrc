# China mirror keeps local installs fast; also works on Vercel (public CDN,
# exact pinned versions with matching integrity from the lockfile).
registry=https://registry.npmmirror.com
fetch-timeout=600000
fetch-retries=6
fetch-retry-maxtimeout=120000
# these native deps' build scripts are intentionally skipped (see pnpm-workspace.yaml allowBuilds)
strict-dep-builds=false
verify-deps-before-run=false
